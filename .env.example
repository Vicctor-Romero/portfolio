# Copy this file to `.env` and fill in the values.
# In production, set the same variables in Netlify:
#   Site settings → Environment variables.

# Resend API key — https://resend.com/api-keys  (required for the contact form)
RESEND_API_KEY=

# Sender address. Must be on a domain verified in Resend.
# Temporary fallback while verifying your domain:
#   CONTACT_FROM="Victor Romero <onboarding@resend.dev>"
CONTACT_FROM="Victor Romero <contact@victorromero.dev>"

# Where contact-form messages are delivered.
CONTACT_TO=vmrbaez@gmail.com
