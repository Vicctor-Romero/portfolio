---
import "../styles/global.css";
import Header from "../components/inicio/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Victor Romero — Software Engineer",
  description = "Victor Romero — software engineer & founder. I engineer web, mobile and backend products end to end.",
} = Astro.props;
const url = "https://www.vicctor-romero.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={url} />

    <!-- Favicon -->
    <link
      rel="icon"
      type="image/png"
      href="https://res.cloudinary.com/dqkckcvl0/image/upload/v1753825897/VR_afn6h2.png"
    />
    <link
      rel="apple-touch-icon"
      href="https://res.cloudinary.com/dqkckcvl0/image/upload/v1753825897/VR_afn6h2.png"
    />

    <!-- Fonts: Space Grotesk (display/UI) + JetBrains Mono (technical) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body data-motion="full">
    <!-- ambient layers -->
    <div class="bg-grid"></div>
    <div class="bg-vignette"></div>
    <div class="scanlines"></div>
    <div class="frame"><i></i><i></i><i></i><i></i></div>
    <div class="reticle"><div class="h"></div><div class="v"></div></div>

    <div class="shell">
      <Header />
      <slot />
      <slot name="footer"><Footer /></slot>
    </div>

    <script>
      /* ===== shared portfolio behaviour ===== */
      const reduce = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      // ---- decode text ----
      const glyphs = "ABCDEFGHIJKLMNOPQRSTUVWXYZ#%&_/\\<>*0123456789";
      function decodeEl(el: HTMLElement) {
        const final = el.dataset.text || (el.textContent || "").trim();
        el.dataset.text = final;
        if (reduce) {
          el.textContent = final;
          return;
        }
        const chars = final.split("");
        const start = performance.now();
        const speed = 55,
          dur = 520;
        function frame(now: number) {
          const t = now - start;
          let out = "",
            done = true;
          for (let i = 0; i < chars.length; i++) {
            const at = i * speed;
            if (chars[i] === " ") {
              out += " ";
              continue;
            }
            if (t > at + dur) {
              out += chars[i];
            } else {
              out += glyphs[Math.floor(Math.random() * glyphs.length)];
              done = false;
            }
          }
          el.textContent = out;
          if (!done) requestAnimationFrame(frame);
          else el.textContent = final;
        }
        requestAnimationFrame(frame);
      }
      function runDecode() {
        document
          .querySelectorAll<HTMLElement>("[data-decode]")
          .forEach((el, i) => {
            setTimeout(() => decodeEl(el), i * 200);
          });
      }
      window.addEventListener("redecode", runDecode);
      runDecode();

      // ---- reticle (crosshair follows cursor) ----
      function startReticle() {
        const h = document.querySelector<HTMLElement>(".reticle .h");
        const v = document.querySelector<HTMLElement>(".reticle .v");
        if (!h || !v || reduce) return;
        let tx = window.innerWidth / 2,
          ty = window.innerHeight / 2,
          cx = tx,
          cy = ty;
        window.addEventListener("mousemove", (e) => {
          tx = e.clientX;
          ty = e.clientY;
        });
        (function loop() {
          cx += (tx - cx) * 0.16;
          cy += (ty - cy) * 0.16;
          h.style.transform = "translateY(" + cy + "px)";
          v.style.transform = "translateX(" + cx + "px)";
          requestAnimationFrame(loop);
        })();
      }
      startReticle();

      // ---- live clock (footer) ----
      function tick() {
        const d = new Date();
        const p = (n: number) => (n < 10 ? "0" : "") + n;
        document.querySelectorAll(".clock").forEach((c) => {
          c.textContent =
            p(d.getHours()) + ":" + p(d.getMinutes()) + ":" + p(d.getSeconds());
        });
      }
      tick();
      setInterval(tick, 1000);
    </script>
  </body>
</html>
