---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import CaseStudy from "../../components/CaseStudy.astro";

export async function getStaticPaths() {
  const entries = await getCollection("projects", (e) => e.id.startsWith("en/"));
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/^en\//, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<MainLayout title={`${entry.data.title} — Victor Romero`}>
  <CaseStudy entry={entry} />
</MainLayout>
