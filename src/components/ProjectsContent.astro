---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getProjects } from "../data/projects";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") return `/es${cleanPath}`;
  return cleanPath;
}

const projects = getProjects(t, getLocalizedPath);
const count = String(projects.length).padStart(2, "0");
---

<main class="page">
  <div class="pagehead">
    <div class="kicker mono">
      <span class="ln"></span>{t("projects.kicker")}
    </div>
    <h1 class="display"><span class="row" data-decode>{t("nav.projects")}</span></h1>
  </div>

  <div class="intro">
    <p>{t("projects.intro")}</p>
    <div class="count mono">
      {t("projects.count")} <b>{count}</b> / {count}
    </div>
  </div>

  <section class="work">
    {
      projects.map((p) => (
        <details class="proj" name="projects">
          <summary>
            <span class="pnum mono">{p.num}</span>
            <span class="pname">{p.title}</span>
            <span class="pmeta mono">{p.listMeta}</span>
            <span class="ind mono" aria-hidden="true" />
          </summary>

          <div class="panel">
            <div class="pinfo">
              <div class="role">
                <span class="pill">{p.rolePill}</span> {p.roleMeta}
              </div>
              <p class="pdesc">{p.description}</p>
              <div class="ptags mono">
                {p.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
              {p.comingSoon ? (
                <span class="visit soon mono">{t("proj.coming_soon")} →</span>
              ) : (
                <a class="visit mono" href={p.visit!.url} target="_blank" rel="noopener">
                  {p.visit!.label} →
                </a>
              )}
            </div>

            <div class="pmedia">
              <span class="tag mono">{p.tag}</span>
              {p.image ? (
                <img src={p.image} alt={p.title} loading="lazy" />
              ) : (
                <div class="media-empty mono">[ {t("proj.coming_soon")} ]</div>
              )}
            </div>
          </div>
        </details>
      ))
    }
  </section>
</main>

<style>
  .intro {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 18px;
    padding-bottom: 8px;
  }
  .intro p {
    max-width: 440px;
    font-size: 15px;
    line-height: 1.6;
    color: #b9bdba;
  }
  .intro .count {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--dim);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .intro .count b {
    color: var(--accent);
  }

  .work {
    margin-top: 14px;
  }

  /* ---- accordion row ---- */
  .proj {
    border-top: 1px solid var(--line);
  }
  .proj:last-child {
    border-bottom: 1px solid var(--line);
  }
  summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding: 22px 0;
    transition: padding 0.2s;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary:hover {
    padding-left: 12px;
  }
  .pnum {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--accent);
    flex-shrink: 0;
  }
  .pname {
    font-size: clamp(1.3rem, 2.6vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  summary:hover .pname,
  .proj[open] .pname {
    color: var(--accent);
  }
  .pmeta {
    font-size: 10.5px;
    letter-spacing: 0.12em;
    color: var(--dim);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .ind {
    margin-left: auto;
    color: var(--dimmer);
    font-size: 16px;
    line-height: 1;
    align-self: center;
    transition: color 0.2s, transform 0.25s;
    flex-shrink: 0;
  }
  .ind::after {
    content: "+";
  }
  summary:hover .ind {
    color: var(--accent);
  }
  .proj[open] .ind {
    color: var(--accent);
    transform: rotate(45deg);
  }

  /* ---- expanded panel ---- */
  .panel {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: center;
    padding: 4px 0 38px;
  }
  .proj[open] .panel {
    animation: reveal 0.3s ease;
  }
  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .role {
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    font-family: var(--font-mono);
  }
  .role .pill {
    border: 1px solid var(--line);
    padding: 4px 8px;
    color: var(--ink);
    white-space: nowrap;
  }
  .pdesc {
    margin-top: 18px;
    max-width: 440px;
    font-size: 15px;
    line-height: 1.65;
    color: #b3b7b4;
  }
  .ptags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 18px;
  }
  .ptags span {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 5px 9px;
  }
  .visit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 24px;
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid transparent;
    padding-bottom: 3px;
    transition: all 0.2s;
    width: fit-content;
  }
  .visit:hover {
    border-color: var(--accent);
    gap: 14px;
  }
  .visit.soon {
    color: var(--dim);
    pointer-events: none;
  }

  .pmedia {
    position: relative;
    aspect-ratio: 16/10;
    border: 1px solid var(--line);
    background: #0b0d0e;
    overflow: hidden;
  }
  .pmedia::before,
  .pmedia::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    opacity: 0.6;
    z-index: 3;
    pointer-events: none;
  }
  .pmedia::before {
    top: 9px;
    left: 9px;
    border-top: 1.5px solid var(--accent);
    border-left: 1.5px solid var(--accent);
  }
  .pmedia::after {
    bottom: 9px;
    right: 9px;
    border-bottom: 1.5px solid var(--accent);
    border-right: 1.5px solid var(--accent);
  }
  .pmedia img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pmedia .tag {
    position: absolute;
    top: 9px;
    right: 9px;
    font-size: 9px;
    letter-spacing: 0.16em;
    color: var(--dimmer);
    z-index: 3;
  }
  .media-empty {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    letter-spacing: 0.24em;
    color: var(--dimmer);
    text-transform: uppercase;
  }

  @media (max-width: 760px) {
    summary {
      flex-wrap: wrap;
      gap: 6px 14px;
    }
    .pmeta {
      width: 100%;
      padding-left: 30px;
      white-space: normal;
    }
    .ind {
      align-self: flex-start;
    }
    .panel {
      grid-template-columns: 1fr;
      gap: 22px;
    }
    .pmedia {
      order: -1;
    }
  }
</style>
