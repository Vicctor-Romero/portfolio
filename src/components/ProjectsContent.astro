---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getProjects } from "../data/projects";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") return `/es${cleanPath}`;
  return cleanPath;
}

const projects = getProjects(t, getLocalizedPath);
const count = String(projects.length).padStart(2, "0");
---

<main class="page">
  <div class="pagehead">
    <div class="kicker mono">
      <span class="ln"></span>{t("projects.kicker")}
    </div>
    <h1 class="display"><span class="row" data-decode>{t("nav.projects")}</span></h1>
  </div>

  <div class="intro">
    <p>{t("projects.intro")}</p>
    <div class="count mono">
      {t("projects.count")} <b>{count}</b> / {count}
    </div>
  </div>

  <section class="work">
    {
      projects.map((p) => (
        <article class="proj">
          <div class="pinfo">
            <div class="num">
              {p.num} — {p.category}
            </div>
            <h2 class="pname">{p.title}</h2>
            <div class="role">
              <span class="pill">{p.rolePill}</span> {p.roleMeta}
            </div>
            <p class="pdesc">{p.description}</p>
            <div class="ptags mono">
              {p.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
            {p.comingSoon ? (
              <span class="visit soon">{t("proj.coming_soon")} →</span>
            ) : (
              <a
                class="visit"
                href={p.visit!.url}
                target="_blank"
                rel="noopener"
              >
                {p.visit!.label} →
              </a>
            )}
          </div>
          <div class="pmedia">
            <span class="tag mono">{p.tag}</span>
            {p.image ? (
              <img src={p.image} alt={p.title} loading="lazy" />
            ) : (
              <div class="media-empty mono">[ {t("proj.coming_soon")} ]</div>
            )}
          </div>
        </article>
      ))
    }
  </section>
</main>

<style>
  .intro {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 18px;
    padding-bottom: 8px;
  }
  .intro p {
    max-width: 440px;
    font-size: 15px;
    line-height: 1.6;
    color: #b9bdba;
  }
  .intro .count {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--dim);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .intro .count b {
    color: var(--accent);
  }

  .work {
    margin-top: 14px;
  }
  .proj {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 4vw, 64px);
    padding: clamp(34px, 5vw, 58px) 0;
    border-top: 1px solid var(--line);
    align-items: center;
  }
  .proj:last-child {
    border-bottom: 1px solid var(--line);
  }
  .proj:nth-child(even) .pmedia {
    order: -1;
  }
  .num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--accent);
  }
  .pname {
    font-size: clamp(2rem, 3.4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 14px 0 12px;
    text-transform: uppercase;
  }
  .role {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .role .pill {
    border: 1px solid var(--line);
    padding: 4px 8px;
    color: var(--ink);
    white-space: nowrap;
  }
  .pdesc {
    margin-top: 20px;
    max-width: 440px;
    font-size: 15px;
    line-height: 1.65;
    color: #b3b7b4;
  }
  .ptags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 20px;
  }
  .ptags span {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 5px 9px;
  }
  .visit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 26px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid transparent;
    padding-bottom: 3px;
    transition: all 0.2s;
    width: fit-content;
    white-space: nowrap;
  }
  .visit:hover {
    border-color: var(--accent);
    gap: 14px;
  }
  .visit.soon {
    color: var(--dim);
    pointer-events: none;
  }

  .pmedia {
    position: relative;
    aspect-ratio: 4/3;
    border: 1px solid var(--line);
    background: #0b0d0e;
    overflow: hidden;
  }
  .pmedia::before {
    content: "";
    position: absolute;
    top: 9px;
    left: 9px;
    width: 14px;
    height: 14px;
    border-top: 1.5px solid var(--accent);
    border-left: 1.5px solid var(--accent);
    opacity: 0.6;
    z-index: 3;
    pointer-events: none;
  }
  .pmedia::after {
    content: "";
    position: absolute;
    bottom: 9px;
    right: 9px;
    width: 14px;
    height: 14px;
    border-bottom: 1.5px solid var(--accent);
    border-right: 1.5px solid var(--accent);
    opacity: 0.6;
    z-index: 3;
    pointer-events: none;
  }
  .pmedia img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pmedia .tag {
    position: absolute;
    top: 9px;
    right: 9px;
    font-size: 9px;
    letter-spacing: 0.16em;
    color: var(--dimmer);
    z-index: 3;
    pointer-events: none;
  }
  .media-empty {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    letter-spacing: 0.24em;
    color: var(--dimmer);
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .proj {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 36px 0;
    }
    .proj:nth-child(even) .pmedia,
    .pmedia {
      order: -1;
    }
  }
</style>
