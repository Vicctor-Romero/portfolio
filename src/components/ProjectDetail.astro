---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getProjects } from "../data/projects";

interface Props {
  projectId: string;
}
const { projectId } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") return `/es${cleanPath}`;
  return cleanPath;
}

const project = getProjects(t, getLocalizedPath).find((p) => p.id === projectId)!;
---

<main class="page">
  <nav class="crumb mono">
    <a href={getLocalizedPath("/projects")}>{t("nav.projects")}</a>
    <span>/</span>
    <span class="cur">{project.title}</span>
  </nav>

  <div class="pagehead">
    <div class="kicker mono">
      <span class="ln"></span>{project.num} — {project.category}
    </div>
    <h1 class="display"><span class="row" data-decode>{project.title}</span></h1>
  </div>

  <section class="detail">
    <div class="info">
      <div class="role">
        <span class="pill">{project.rolePill}</span>
        {project.roleMeta}
      </div>
      <p class="pdesc">{project.description}</p>
      <div class="ptags mono">
        {project.tags.map((tag) => <span>{tag}</span>)}
      </div>
      {
        project.comingSoon ? (
          <span class="visit soon mono">{t("proj.coming_soon")} →</span>
        ) : (
          <a class="visit mono" href={project.visit!.url} target="_blank" rel="noopener">
            {project.visit!.label} →
          </a>
        )
      }
      <div class="backrow">
        <a class="back mono" href={getLocalizedPath("/projects")}>← {t("nav.projects")}</a>
      </div>
    </div>

    <div class="pmedia">
      <span class="tag mono">{project.tag}</span>
      {
        project.image ? (
          <img src={project.image} alt={project.title} loading="lazy" />
        ) : (
          <div class="media-empty mono">[ {t("proj.coming_soon")} ]</div>
        )
      }
    </div>
  </section>
</main>

<style>
  .crumb {
    display: flex;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
    margin-top: 8px;
  }
  .crumb a:hover {
    color: var(--accent);
  }
  .crumb .cur {
    color: var(--ink);
  }

  .detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 4vw, 64px);
    align-items: center;
    margin-top: 24px;
    padding-top: clamp(20px, 4vw, 40px);
    border-top: 1px solid var(--line);
  }
  .role {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .role .pill {
    border: 1px solid var(--line);
    padding: 4px 8px;
    color: var(--ink);
  }
  .pdesc {
    margin-top: 20px;
    max-width: 460px;
    font-size: 15px;
    line-height: 1.7;
    color: #b3b7b4;
  }
  .ptags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 22px;
  }
  .ptags span {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 5px 9px;
  }
  .visit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid transparent;
    padding-bottom: 3px;
    transition: all 0.2s;
    width: fit-content;
  }
  .visit:hover {
    border-color: var(--accent);
    gap: 14px;
  }
  .visit.soon {
    color: var(--dim);
    pointer-events: none;
  }
  .backrow {
    margin-top: 36px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }
  .back {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    transition: color 0.2s;
  }
  .back:hover {
    color: var(--accent);
  }

  .pmedia {
    position: relative;
    aspect-ratio: 4/3;
    border: 1px solid var(--line);
    background: #0b0d0e;
    overflow: hidden;
  }
  .pmedia::before,
  .pmedia::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    opacity: 0.6;
    z-index: 3;
    pointer-events: none;
  }
  .pmedia::before {
    top: 9px;
    left: 9px;
    border-top: 1.5px solid var(--accent);
    border-left: 1.5px solid var(--accent);
  }
  .pmedia::after {
    bottom: 9px;
    right: 9px;
    border-bottom: 1.5px solid var(--accent);
    border-right: 1.5px solid var(--accent);
  }
  .pmedia img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pmedia .tag {
    position: absolute;
    top: 9px;
    right: 9px;
    font-size: 9px;
    letter-spacing: 0.16em;
    color: var(--dimmer);
    z-index: 3;
  }
  .media-empty {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    letter-spacing: 0.24em;
    color: var(--dimmer);
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .detail {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .pmedia {
      order: -1;
    }
  }
</style>
