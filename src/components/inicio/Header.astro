---
import {
  getLangFromUrl,
  useTranslations,
  getRouteFromUrl,
} from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const route = getRouteFromUrl(Astro.url);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") {
    return `/es${cleanPath}`;
  }
  return cleanPath;
}

const nextLang = lang === "en" ? "es" : "en";
const nextUrl = nextLang === "en" ? `/${route}` : `/es/${route}`;

const links = [
  { href: "/projects", key: "nav.projects" as const, route: "projects" },
  { href: "/about", key: "nav.about" as const, route: "about" },
  { href: "/contact", key: "nav.contact" as const, route: "contact" },
];
---

<header class="nav">
  <a class="brand" href={lang === "es" ? "/es" : "/"}>
    <img
      class="logo"
      src="https://res.cloudinary.com/dqkckcvl0/image/upload/v1753825897/VR_afn6h2.png"
      alt="VR"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
    />
    <span class="fallback" style="display:none">VR</span>
    <span class="who"><b>Victor Romero</b><span>SOFTWARE ENGINEER</span></span>
  </a>

  <nav class="navlinks">
    {
      links.map((l) => (
        <a
          href={getLocalizedPath(l.href)}
          class:list={[route === l.route && "active"]}
        >
          {t(l.key)}
        </a>
      ))
    }
  </nav>

  <div class="navright">
    <a href={nextUrl} class="lang mono" aria-label="Switch language">
      <span class:list={[lang === "en" ? "text-ink" : "text-dim"]}>EN</span>
      <b>/</b>
      <span class:list={[lang === "es" ? "text-ink" : "text-dim"]}>ES</span>
    </a>
    <a class="btn" href={getLocalizedPath("/contact")}>
      <span class="dot"></span>{t("nav.cta")}
    </a>
    <button id="navtoggle" class="navtoggle" aria-label="Toggle menu">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- mobile menu -->
  <div id="mobilemenu" class="mobilemenu">
    <nav>
      {
        links.map((l) => (
          <a
            href={getLocalizedPath(l.href)}
            class:list={[route === l.route && "active"]}
          >
            {t(l.key)}
          </a>
        ))
      }
      <a href={nextUrl}>{lang === "en" ? "ES — Español" : "EN — English"}</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("navtoggle");
  const menu = document.getElementById("mobilemenu");
  const icon = btn?.querySelector("svg path");
  let open = false;

  function setOpen(v: boolean) {
    open = v;
    menu?.classList.toggle("open", open);
    icon?.setAttribute("d", open ? "M6 18L18 6M6 6l12 12" : "M4 6h16M4 12h16M4 18h16");
  }

  btn?.addEventListener("click", (e) => {
    e.stopPropagation();
    setOpen(!open);
  });

  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => setOpen(false)),
  );

  document.addEventListener("click", (e) => {
    if (
      open &&
      !btn?.contains(e.target as Node) &&
      !menu?.contains(e.target as Node)
    ) {
      setOpen(false);
    }
  });
</script>
