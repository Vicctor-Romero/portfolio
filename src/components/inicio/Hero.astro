---
import CuboAnimated from "../CuboAnimated.tsx";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") return `/es${cleanPath}`;
  return cleanPath;
}

const kickerParts = t("home.kicker").split(" · ");
const stack = [
  "REACT",
  "NEXT.JS",
  "NESTJS",
  "REACT NATIVE",
  "POSTGRESQL",
  "TYPESCRIPT",
];
---

<main class="hero">
  <div class="left">
    <div class="kicker k-home mono">
      <span class="ln"></span>{
        kickerParts.map((p, i) => (
          <>
            {i > 0 && <b>·</b>}
            {p}
          </>
        ))
      }
    </div>
    <h1 class="display">
      <span class="row" data-decode>VICTOR</span>
      <span class="row stroked" data-decode>ROMERO</span>
    </h1>
    <p class="lead" set:html={t("home.lead")} />
    <div class="stack mono">
      {stack.map((s) => <span>{s}</span>)}
    </div>
    <div class="cta">
      <a class="primary mono" href={getLocalizedPath("/projects")}>
        {t("home.cta.view")} <span>›</span>
      </a>
      <a class="ghost mono" href={getLocalizedPath("/contact")}>
        {t("home.cta.talk")}
      </a>
    </div>
  </div>

  <div class="right">
    <div class="cube-wrap">
      <div class="cube-coords tl mono">X:42.0<br />Y:13.7</div>
      <div class="cube-coords br mono"><b>SYS</b> ONLINE<br />RENDER:GPU</div>
      <div class="cube-canvas">
        <CuboAnimated variant="terminal" client:only="react" />
      </div>
      <a class="cube-solve" href={getLocalizedPath("/about")}>
        <span class="cmd mono">&gt; {t("home.cube.solve")}_</span>
        <span class="sub mono">{t("home.cube.sub")}</span>
      </a>
    </div>
  </div>
</main>

<style>
  .hero {
    flex: 1;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: 40px;
    padding: 14px 0 8px;
  }
  .left {
    max-width: 680px;
  }
  .k-home {
    margin-bottom: 26px;
  }
  .lead {
    margin-top: 30px;
    max-width: 500px;
    font-size: clamp(15px, 1.15vw, 18px);
    line-height: 1.6;
    color: #b9bdba;
  }
  .lead :global(b) {
    color: var(--ink);
    font-weight: 500;
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 10px;
    margin-top: 30px;
  }
  .stack span {
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 6px 10px;
    transition: all 0.2s;
  }
  .stack span:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .cta {
    display: flex;
    gap: 14px;
    margin-top: 34px;
    flex-wrap: wrap;
  }
  .cta a {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 14px 24px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.22s;
    cursor: pointer;
  }
  .cta .primary {
    background: var(--accent);
    color: #05140b;
    font-weight: 500;
  }
  .cta .primary:hover {
    box-shadow: 0 0 34px -4px var(--accent);
    transform: translateY(-2px);
  }
  .cta .ghost {
    border: 1px solid var(--line);
    color: var(--ink);
  }
  .cta .ghost:hover {
    border-color: var(--ink);
  }

  .right {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    height: 100%;
  }
  .cube-wrap {
    position: relative;
    width: min(46vh, 420px);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cube-coords {
    position: absolute;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--dimmer);
    z-index: 3;
    pointer-events: none;
  }
  .cube-coords.tl {
    top: -6px;
    left: -6px;
  }
  .cube-coords.br {
    bottom: -6px;
    right: -6px;
    text-align: right;
  }
  .cube-coords b {
    color: var(--accent);
    font-weight: 500;
  }
  .cube-canvas {
    position: absolute;
    inset: 0;
  }
  .cube-solve {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 14px;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.25s;
    background: radial-gradient(
      ellipse 70% 50% at 50% 100%,
      rgba(8, 9, 10, 0.85),
      transparent 75%
    );
    z-index: 4;
  }
  .cube-wrap:hover .cube-solve,
  .cube-solve:focus-visible {
    opacity: 1;
  }
  .cube-solve .cmd {
    font-size: 15px;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-shadow: 0 0 14px rgba(59, 255, 136, 0.5);
  }
  .cube-solve .sub {
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 8px 0;
    }
    .right {
      order: -1;
      height: auto;
      margin-top: 6px;
    }
    .cube-wrap {
      width: min(40vh, 300px);
    }
  }
</style>
