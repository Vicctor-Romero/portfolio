</main>

<script>
  // Collapse long collections: show the first data-show items, reveal the rest
  // with a toggle button.
  document.querySelectorAll<HTMLElement>(".collapsewrap").forEach((wrap) => {
    const show = Number(wrap.dataset.show || "6");
    const grid = wrap.firstElementChild as HTMLElement | null;
    const btn = wrap.querySelector<HTMLButtonElement>(".morebtn");
    if (!grid || !btn) return;
    const items = Array.from(grid.children) as HTMLElement[];
    if (items.length <= show) {
      btn.remove();
      return;
    }
    const extra = items.slice(show);
    const moreTpl = btn.dataset.more || "+ {n} more";
    const lessTpl = btn.dataset.less || "Show less";
    const render = (open: boolean) => {
      extra.forEach((el) => el.classList.toggle("is-hidden", !open));
      btn.textContent = open
        ? lessTpl
        : moreTpl.replace("{n}", String(extra.length));
    };
    render(false);
    btn.addEventListener("click", () =>
      render(extra[0].classList.contains("is-hidden")),
    );
  });
</script>

