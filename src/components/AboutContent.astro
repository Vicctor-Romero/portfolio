---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import InteractiveCube from "./InteractiveCube.tsx";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") return `/es${cleanPath}`;
  return cleanPath;
}

const skills = [
  { h: "Frontend", items: ["React", "Next.js", "TypeScript", "Tailwind"] },
  { h: "Backend", items: ["NestJS", "Node.js", "PostgreSQL", "REST / GraphQL"] },
  { h: "Mobile", items: ["React Native", "Expo", "Push / OTA", "App Store / Play"] },
  { h: "Infra", items: ["Docker", "CI / CD", "AWS / Vercel", "Git"] },
];

// On Repeat: each cover links out to Spotify.
//   cover = album artwork image URL (e.g. the Spotify cover image)
//   url   = Spotify link to the track/album (Share → Copy link)
// Fill these with your real favorites; empty entries show a placeholder.
const albums: { album: string; artist: string; cover: string; url: string }[] = [
  { album: "Sunrise", artist: "Simply Red", cover: "https://i.scdn.co/image/ab67616d0000b27317a3d8e105d4f872fc66893d", url: "https://open.spotify.com/track/4LxDdYU3x9tyDxy3CghqdC" },
  { album: "High Hopes", artist: "Pink Floyd", cover: "https://i.scdn.co/image/ab67616d0000b273f508f0949710aa33a79cf6b2", url: "https://open.spotify.com/track/5a4MgIUSf9K8wXLSm6xPEx" },
  { album: "Kill Me", artist: "Hayley Williams", cover: "https://i.scdn.co/image/ab67616d0000b2734f422ed700af8715b23326af", url: "https://open.spotify.com/track/3yiWkaQvp8cYt64M1bSVb9" },
  { album: "Don't Forget Me", artist: "Red Hot Chili Peppers", cover: "https://i.scdn.co/image/ab67616d0000b273de1af2785a83cc660155a0c4", url: "https://open.spotify.com/track/308kjPoIVBzDNExO54sqAi" },
  { album: "Silverflame", artist: "Dizzy Mizz Lizzy", cover: "https://i.scdn.co/image/ab67616d0000b2737ec8a4d551207a6874fbbbbf", url: "https://open.spotify.com/track/2fwfZDXNBxx2alE6clKQcZ" },
  { album: "City Life", artist: "Rebelution", cover: "https://i.scdn.co/image/ab67616d0000b27390f8713033cb2f6bf3126569", url: "https://open.spotify.com/track/1ozK6iAeBgCOSXecRojzMo" },
  { album: "2448", artist: "deadmau5", cover: "https://i.scdn.co/image/ab67616d0000b273a43f9418af7e912a42b40d27", url: "https://open.spotify.com/track/1GFxA50oIo05KP5v8ccqKk" },
  { album: "High", artist: "Sir Sly", cover: "https://i.scdn.co/image/ab67616d0000b273afffc8aea37762b4daa91e8b", url: "https://open.spotify.com/track/17aDyX39gb1iV1ZWvD1ffE" },
  { album: "Paranoid", artist: "Black Sabbath", cover: "https://i.scdn.co/image/ab67616d0000b273605b25c031f809d78054a13c", url: "https://open.spotify.com/track/3Jnxngdff0lVu2rza1GVx6" },
  { album: "Could Have Been Me", artist: "The Struts", cover: "https://i.scdn.co/image/ab67616d0000b27301fc57d639133319122c4ff4", url: "https://open.spotify.com/track/3IyCL4Em1GOpNGDf451Hg1" },
  { album: "My Blood", artist: "Twenty One Pilots", cover: "https://i.scdn.co/image/ab67616d0000b273d1d301e737da4324479c6660", url: "https://open.spotify.com/track/5HeKOKc4phmLn8e4I7EkzD" },
  { album: "Nueva Tierra", artist: "Xican", cover: "https://i.scdn.co/image/ab67616d0000b273c2ca50934fc2d073cb3a5101", url: "https://open.spotify.com/track/5BZignIxSCrb0FramLkloj" },
  { album: "0 GRAVITY", artist: "Zior Park", cover: "https://i.scdn.co/image/ab67616d0000b27314dabc27dec03c4ea1ffd576", url: "https://open.spotify.com/track/7yc7XqMqoJZe28MfPqDjVg" },
  { album: "Gone Forever", artist: "Three Days Grace", cover: "https://i.scdn.co/image/ab67616d0000b273e773763694ac5eb7f2aa0a37", url: "https://open.spotify.com/track/2Xe2YAxNPqWCNpZ8RagBdO" },
  { album: "Let You Down", artist: "Seether", cover: "https://i.scdn.co/image/ab67616d0000b273ac3fb5916dd26f3f87609b06", url: "https://open.spotify.com/track/2UcXM8xEP95IYz7rguHSnA" },
];
// On the Shelf: books I've read. cover = Google Books cover (by volume id),
// url = the Google Books edition page.
const books: { title: string; author: string; cover: string; url: string }[] = [
  { title: "The Martian", author: "Andy Weir", cover: "https://books.google.com/books/content?id=2NIpDAAAQBAJ&printsec=frontcover&img=1&zoom=1", url: "https://www.google.com/books/edition/The_Martian/2NIpDAAAQBAJ" },
  { title: "Project Hail Mary", author: "Andy Weir", cover: "https://books.google.com/books/content?id=GrYsEAAAQBAJ&printsec=frontcover&img=1&zoom=1", url: "https://www.google.com/books/edition/Project_Hail_Mary/GrYsEAAAQBAJ" },
  { title: "Artemis", author: "Andy Weir", cover: "https://books.google.com/books/content?id=qqg_DwAAQBAJ&printsec=frontcover&img=1&zoom=1", url: "https://www.google.com/books/edition/Artemis/qqg_DwAAQBAJ" },
  { title: "La sombra del viento", author: "Carlos Ruiz Zafón", cover: "https://books.google.com/books/content?id=I3m2qUbB5hIC&printsec=frontcover&img=1&zoom=1", url: "https://www.google.com/books/edition/La_sombra_del_viento_Shadow_of_the_Wind/I3m2qUbB5hIC" },
  { title: "El juego del ángel", author: "Carlos Ruiz Zafón", cover: "https://books.google.com/books/content?id=1msZEAAAQBAJ&printsec=frontcover&img=1&zoom=1", url: "https://www.google.com/books/edition/El_juego_del_angel/1msZEAAAQBAJ" },
  { title: "El Laberinto de los Espíritus", author: "Carlos Ruiz Zafón", cover: "https://books.google.com/books/content?id=JTE7DwAAQBAJ&printsec=frontcover&img=1&zoom=1", url: "https://www.google.com/books/edition/El_Laberinto_de_los_Esp%C3%ADritus_The_Labyri/JTE7DwAAQBAJ" },
  { title: "El Prisionero del Cielo", author: "Carlos Ruiz Zafón", cover: "https://books.google.com/books/content?id=S7O6pV1qXj0C&printsec=frontcover&img=1&zoom=1", url: "https://www.google.com/books/edition/El_Prisionero_del_Cielo_The_Prisoner_of_/S7O6pV1qXj0C" },
];

const cubeLabels = {
  scramble: t("about.cube.scramble"),
  reset: t("about.cube.reset"),
  solved: t("about.cube.solved"),
  scrambled: t("about.cube.scrambled"),
  status: t("about.cube.status"),
};
---

<main class="page">
  <div class="pagehead">
    <div class="kicker mono"><span class="ln"></span>{t("about.kicker")}</div>
    <h1 class="display"><span class="row" data-decode>{t("nav.about")}</span></h1>
  </div>

  <!-- BIO -->
  <section class="sec" style="border-top:none;padding-top:18px">
    <div class="bio">
      <div>
        <div class="term">
          <span class="l"><span class="p">$</span><span class="g">whoami</span></span>
          <span class="l"><span class="c">► {t("about.term.l1")}</span></span>
          <span class="l"><span class="c">► {t("about.term.l2")}</span></span>
          <span class="l"
            ><span class="c"
              >► {t("about.term.l3")}
              <b style="color:var(--accent);font-weight:500">Glidocs</b>.</span
            ></span
          >
          <span class="l"
            ><span class="c"
              >► {t("about.term.l4")}<span class="cursor"></span></span
            ></span
          >
        </div>
        <p class="bigstate" set:html={t("about.bigstate")} />
      </div>
    </div>
  </section>

  <!-- SOLVE IT (interactive cube) -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.cube.title")}</h2>
      <span class="hint mono">{t("about.cube.hint")}</span>
    </div>
    <div class="cubegrid">
      <InteractiveCube labels={cubeLabels} client:only="react" />
      <div class="cubetext">
        <p class="bigstate" style="margin-top:0">{t("about.cube.lead")}</p>
      </div>
    </div>
  </section>

  <!-- TOOLKIT -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.toolkit")}</h2>
      <span class="hint mono">{t("about.toolkit.hint")}</span>
    </div>
    <div class="skills">
      {
        skills.map((s) => (
          <div class="skill">
            <h3>{s.h}</h3>
            <ul>
              {s.items.map((i) => (
                <li>{i}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ON REPEAT -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.onrepeat")}</h2>
      <span class="hint mono">{t("about.onrepeat.hint")}</span>
    </div>
    <div class="nowbar mono">
      <span class="live"><span class="blip"></span>{t("about.onrepeat.live")}</span>
      <span>{t("about.onrepeat.note")}</span>
    </div>
    <div class="albums">
      {
        albums.map((a) => (
          <a
            class="album"
            href={a.url || undefined}
            target={a.url ? "_blank" : undefined}
            rel="noopener"
          >
            <div class="cover">
              {a.cover ? (
                <img src={a.cover} alt={a.album} loading="lazy" />
              ) : (
                <div class="img-empty mono">cover</div>
              )}
              <div class="eq">
                <i /><i /><i /><i /><i /><i /><i />
              </div>
            </div>
            <div class="cap mono">
              <b>{a.album}</b>
              {a.artist}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- OFF THE CLOCK -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.offclock")}</h2>
      <span class="hint mono">{t("about.offclock.hint")}</span>
    </div>
    <div class="shelf">
      {
        books.map((b) => (
          <a
            class="book"
            href={b.url || undefined}
            target={b.url ? "_blank" : undefined}
            rel="noopener"
          >
            <div class="bcover">
              {b.cover ? (
                <img src={b.cover} alt={b.title} loading="lazy" />
              ) : (
                <div class="img-empty mono">book</div>
              )}
            </div>
            <div class="bcap mono">
              <b>{b.title}</b>
              {b.author}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- CLOSING -->
  <section class="closing">
    <h2>{t("about.closing.1")}<br /><em>{t("about.closing.2")}</em></h2>
    <a class="btn" href={getLocalizedPath("/contact")}>
      <span class="dot"></span>{t("nav.cta")}
    </a>
  </section>
</main>

<style>
  .sec {
    padding: clamp(34px, 5vw, 64px) 0;
    border-top: 1px solid var(--line);
  }
  .sechead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }
  .sechead h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .sechead .hint {
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--dimmer);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  /* generic empty image placeholder */
  .img-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12px;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #4b524e;
    background: rgba(255, 255, 255, 0.02);
  }
  .img-empty img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* bio */
  .bio {
    max-width: 640px;
  }
  .term {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 2;
    color: #b9bdba;
  }
  .term .l {
    display: block;
  }
  .term .p {
    color: var(--accent);
    margin-right: 8px;
  }
  .term .g {
    color: var(--ink);
  }
  .term .c {
    color: var(--dim);
  }
  .bigstate {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-top: 30px;
    max-width: 560px;
    font-weight: 500;
  }
  .bigstate :global(em) {
    font-style: normal;
    color: var(--accent);
  }

  /* interactive cube */
  .cubegrid {
    display: grid;
    grid-template-columns: minmax(0, 440px) 1fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }

  /* skills */
  .skills {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .skill {
    background: var(--bg);
    padding: 22px 20px;
  }
  .skill h3 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .skill ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .skill li {
    font-size: 14px;
    color: #c2c6c3;
    display: flex;
    align-items: center;
    gap: 9px;
  }
  .skill li::before {
    content: "▸";
    color: var(--dimmer);
  }

  /* album wall */
  .albums {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 14px;
  }
  .album {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .cover {
    position: relative;
    aspect-ratio: 1;
    border: 1px solid var(--line);
    overflow: hidden;
    transition:
      transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.3s,
      filter 0.3s,
      border-color 0.3s;
    background: #0b0d0e;
  }
  .albums:hover .album .cover {
    filter: grayscale(0.7) brightness(0.7);
  }
  .album:hover .cover {
    transform: scale(1.06) translateY(-4px);
    filter: none !important;
    border-color: var(--accent);
    box-shadow:
      0 18px 40px -16px rgba(0, 0, 0, 0.9),
      0 0 0 1px var(--accent);
    z-index: 5;
  }
  .eq {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 38px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 3px;
    padding: 8px;
    background: linear-gradient(to top, rgba(4, 7, 5, 0.9), transparent);
    opacity: 0;
    transition: opacity 0.25s;
    z-index: 2;
    pointer-events: none;
  }
  .album:hover .eq {
    opacity: 1;
  }
  .eq i {
    width: 3px;
    background: var(--accent);
    height: 20%;
    box-shadow: 0 0 6px -1px var(--accent);
    animation: eq 0.9s ease-in-out infinite;
  }
  .eq i:nth-child(2) {
    animation-delay: -0.2s;
  }
  .eq i:nth-child(3) {
    animation-delay: -0.5s;
  }
  .eq i:nth-child(4) {
    animation-delay: -0.1s;
  }
  .eq i:nth-child(5) {
    animation-delay: -0.35s;
  }
  .eq i:nth-child(6) {
    animation-delay: -0.6s;
  }
  .eq i:nth-child(7) {
    animation-delay: -0.25s;
  }
  @keyframes eq {
    0%,
    100% {
      height: 16%;
    }
    50% {
      height: 92%;
    }
  }
  .cap {
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--dim);
    line-height: 1.5;
    transition: color 0.2s;
  }
  .cap b {
    display: block;
    color: #c2c6c3;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .album:hover .cap b {
    color: var(--accent);
  }
  .nowbar {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--dim);
    flex-wrap: wrap;
  }
  .nowbar .live {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--accent);
  }
  .nowbar .live .blip {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent);
    animation: blip 1.6s ease-out infinite;
  }
  @keyframes blip {
    0% {
      box-shadow: 0 0 0 0 rgba(59, 255, 136, 0.5);
    }
    100% {
      box-shadow: 0 0 0 9px rgba(59, 255, 136, 0);
    }
  }

  /* bookshelf */
  .shelf {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 18px 16px;
  }
  .book {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .bcover {
    position: relative;
    aspect-ratio: 2/3;
    border: 1px solid var(--line);
    overflow: hidden;
    background: #0b0d0e;
    transition:
      transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.3s,
      filter 0.3s,
      border-color 0.3s;
  }
  .shelf:hover .book .bcover {
    filter: grayscale(0.7) brightness(0.7);
  }
  .book:hover .bcover {
    transform: translateY(-6px);
    filter: none !important;
    border-color: var(--accent);
    box-shadow:
      0 18px 40px -16px rgba(0, 0, 0, 0.9),
      0 0 0 1px var(--accent);
    z-index: 5;
  }
  .bcover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bcap {
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--dim);
    line-height: 1.5;
  }
  .bcap b {
    display: block;
    color: #c2c6c3;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .book:hover .bcap b {
    color: var(--accent);
  }

  /* closing */
  .closing {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
    padding: clamp(34px, 5vw, 60px) 0;
    border-top: 1px solid var(--line);
  }
  .closing h2 {
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 1;
  }
  .closing h2 em {
    font-style: normal;
    color: transparent;
    -webkit-text-stroke: 1.3px var(--ink);
  }

  @media (max-width: 860px) {
    .cubegrid {
      grid-template-columns: 1fr;
    }
    .skills {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .skills {
      grid-template-columns: 1fr;
    }
    .albums {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
