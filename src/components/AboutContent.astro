            return (
              <a
                class="cert"
                href={c.url || undefined}
                target={c.url ? "_blank" : undefined}
                rel="noopener"
              >
                <div class="cmedia">
                  {c.image ? (
                    <img src={c.image} alt={title} loading="lazy" />
                  ) : (
                    <div class="img-empty mono">certificate</div>
                  )}
                </div>
                <div class="cbody">
                  <div class="cissuer mono">{c.issuer}</div>
                  <h3 class="ctitle">{title}</h3>
                  <div class="cfoot mono">
                    <span class="cyear">{c.date.slice(0, 4)}</span>
                    {c.url && <span class="carr">{t("about.certs.verify")} ↗</span>}
