---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import InteractiveCube from "./InteractiveCube.tsx";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") return `/es${cleanPath}`;
  return cleanPath;
}

const skills = [
  { h: "Frontend", items: ["React", "Next.js", "TypeScript", "Tailwind"] },
  { h: "Backend", items: ["NestJS", "Node.js", "PostgreSQL", "REST / GraphQL"] },
  { h: "Mobile", items: ["React Native", "Expo", "Push / OTA", "App Store / Play"] },
  { h: "Infra", items: ["Docker", "CI / CD", "AWS / Vercel", "Git"] },
];

// Album covers + photos: drop real image URLs into `src` to fill them.
const albums = [
  { album: "Album one", artist: "Artist", src: "" },
  { album: "Album two", artist: "Artist", src: "" },
  { album: "Album three", artist: "Artist", src: "" },
  { album: "Album four", artist: "Artist", src: "" },
  { album: "Album five", artist: "Artist", src: "" },
  { album: "Album six", artist: "Artist", src: "" },
  { album: "Album seven", artist: "Artist", src: "" },
  { album: "Album eight", artist: "Artist", src: "" },
];
const photos = [
  { cap: "01 · somewhere", w: 200, h: 240, src: "" },
  { cap: "02 · the setup", w: 260, h: 190, src: "" },
  { cap: "03 · off-grid", w: 200, h: 240, src: "" },
  { cap: "04 · good company", w: 240, h: 200, src: "" },
  { cap: "05 · the view", w: 210, h: 230, src: "" },
];

const cubeLabels = {
  scramble: t("about.cube.scramble"),
  reset: t("about.cube.reset"),
  solved: t("about.cube.solved"),
  scrambled: t("about.cube.scrambled"),
  status: t("about.cube.status"),
};
---

<main class="page">
  <div class="pagehead">
    <div class="kicker mono"><span class="ln"></span>{t("about.kicker")}</div>
    <h1 class="display"><span class="row" data-decode>{t("nav.about")}</span></h1>
  </div>

  <!-- BIO -->
  <section class="sec" style="border-top:none;padding-top:18px">
    <div class="bio">
      <div class="portrait">
        <span class="tag mono">[ VR.JPG ]</span>
        <div class="img-empty mono">drop a photo of you</div>
      </div>
      <div>
        <div class="term">
          <span class="l"><span class="p">$</span><span class="g">whoami</span></span>
          <span class="l"><span class="c">► {t("about.term.l1")}</span></span>
          <span class="l"><span class="c">► {t("about.term.l2")}</span></span>
          <span class="l"
            ><span class="c"
              >► {t("about.term.l3")}
              <b style="color:var(--accent);font-weight:500">Glidocs</b>.</span
            ></span
          >
          <span class="l"
            ><span class="c"
              >► {t("about.term.l4")}<span class="cursor"></span></span
            ></span
          >
        </div>
        <p class="bigstate" set:html={t("about.bigstate")} />
      </div>
    </div>
  </section>

  <!-- SOLVE IT (interactive cube) -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.cube.title")}</h2>
      <span class="hint mono">{t("about.cube.hint")}</span>
    </div>
    <div class="cubegrid">
      <InteractiveCube labels={cubeLabels} client:only="react" />
      <div class="cubetext">
        <p class="bigstate" style="margin-top:0">{t("about.cube.lead")}</p>
      </div>
    </div>
  </section>

  <!-- TOOLKIT -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.toolkit")}</h2>
      <span class="hint mono">{t("about.toolkit.hint")}</span>
    </div>
    <div class="skills">
      {
        skills.map((s) => (
          <div class="skill">
            <h3>{s.h}</h3>
            <ul>
              {s.items.map((i) => (
                <li>{i}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ON REPEAT -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.onrepeat")}</h2>
      <span class="hint mono">{t("about.onrepeat.hint")}</span>
    </div>
    <div class="nowbar mono">
      <span class="live"><span class="blip"></span>{t("about.onrepeat.live")}</span>
      <span>{t("about.onrepeat.note")}</span>
    </div>
    <div class="albums">
      {
        albums.map((a) => (
          <div class="album">
            <div class="cover">
              {a.src ? (
                <img src={a.src} alt={a.album} loading="lazy" />
              ) : (
                <div class="img-empty mono">cover</div>
              )}
              <div class="eq">
                <i /><i /><i /><i /><i /><i /><i />
              </div>
            </div>
            <div class="cap mono">
              <b>{a.album}</b>
              {a.artist}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- OFF THE CLOCK -->
  <section class="sec">
    <div class="sechead">
      <h2>{t("about.offclock")}</h2>
      <span class="hint mono">{t("about.offclock.hint")}</span>
    </div>
    <div class="gallery">
      {
        photos.map((p) => (
          <div class="photo">
            <div
              class="img-empty mono"
              style={`width:${p.w}px;height:${p.h}px`}
            >
              {p.src ? <img src={p.src} alt={p.cap} loading="lazy" /> : "drop a photo"}
            </div>
            <div class="ph-cap mono">{p.cap}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CLOSING -->
  <section class="closing">
    <h2>{t("about.closing.1")}<br /><em>{t("about.closing.2")}</em></h2>
    <a class="btn" href={getLocalizedPath("/contact")}>
      <span class="dot"></span>{t("nav.cta")}
    </a>
  </section>
</main>

<style>
  .sec {
    padding: clamp(34px, 5vw, 64px) 0;
    border-top: 1px solid var(--line);
  }
  .sechead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }
  .sechead h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .sechead .hint {
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--dimmer);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  /* generic empty image placeholder */
  .img-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12px;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #4b524e;
    background: rgba(255, 255, 255, 0.02);
  }
  .img-empty img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* bio */
  .bio {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: start;
  }
  .portrait {
    position: relative;
    aspect-ratio: 3/4;
    border: 1px solid var(--line);
    background: #0b0d0e;
    overflow: hidden;
  }
  .portrait .tag {
    position: absolute;
    bottom: 9px;
    left: 9px;
    font-size: 9px;
    letter-spacing: 0.14em;
    color: var(--accent);
    z-index: 3;
    pointer-events: none;
  }
  .term {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 2;
    color: #b9bdba;
  }
  .term .l {
    display: block;
  }
  .term .p {
    color: var(--accent);
    margin-right: 8px;
  }
  .term .g {
    color: var(--ink);
  }
  .term .c {
    color: var(--dim);
  }
  .bigstate {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-top: 30px;
    max-width: 560px;
    font-weight: 500;
  }
  .bigstate :global(em) {
    font-style: normal;
    color: var(--accent);
  }

  /* interactive cube */
  .cubegrid {
    display: grid;
    grid-template-columns: minmax(0, 440px) 1fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }

  /* skills */
  .skills {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .skill {
    background: var(--bg);
    padding: 22px 20px;
  }
  .skill h3 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .skill ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .skill li {
    font-size: 14px;
    color: #c2c6c3;
    display: flex;
    align-items: center;
    gap: 9px;
  }
  .skill li::before {
    content: "▸";
    color: var(--dimmer);
  }

  /* album wall */
  .albums {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 14px;
  }
  .album {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .cover {
    position: relative;
    aspect-ratio: 1;
    border: 1px solid var(--line);
    overflow: hidden;
    transition:
      transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.3s,
      filter 0.3s,
      border-color 0.3s;
    background: #0b0d0e;
  }
  .albums:hover .album .cover {
    filter: grayscale(0.7) brightness(0.7);
  }
  .album:hover .cover {
    transform: scale(1.06) translateY(-4px);
    filter: none !important;
    border-color: var(--accent);
    box-shadow:
      0 18px 40px -16px rgba(0, 0, 0, 0.9),
      0 0 0 1px var(--accent);
    z-index: 5;
  }
  .eq {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 38px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 3px;
    padding: 8px;
    background: linear-gradient(to top, rgba(4, 7, 5, 0.9), transparent);
    opacity: 0;
    transition: opacity 0.25s;
    z-index: 2;
    pointer-events: none;
  }
  .album:hover .eq {
    opacity: 1;
  }
  .eq i {
    width: 3px;
    background: var(--accent);
    height: 20%;
    box-shadow: 0 0 6px -1px var(--accent);
    animation: eq 0.9s ease-in-out infinite;
  }
  .eq i:nth-child(2) {
    animation-delay: -0.2s;
  }
  .eq i:nth-child(3) {
    animation-delay: -0.5s;
  }
  .eq i:nth-child(4) {
    animation-delay: -0.1s;
  }
  .eq i:nth-child(5) {
    animation-delay: -0.35s;
  }
  .eq i:nth-child(6) {
    animation-delay: -0.6s;
  }
  .eq i:nth-child(7) {
    animation-delay: -0.25s;
  }
  @keyframes eq {
    0%,
    100% {
      height: 16%;
    }
    50% {
      height: 92%;
    }
  }
  .cap {
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--dim);
    line-height: 1.5;
    transition: color 0.2s;
  }
  .cap b {
    display: block;
    color: #c2c6c3;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .album:hover .cap b {
    color: var(--accent);
  }
  .nowbar {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--dim);
    flex-wrap: wrap;
  }
  .nowbar .live {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--accent);
  }
  .nowbar .live .blip {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent);
    animation: blip 1.6s ease-out infinite;
  }
  @keyframes blip {
    0% {
      box-shadow: 0 0 0 0 rgba(59, 255, 136, 0.5);
    }
    100% {
      box-shadow: 0 0 0 9px rgba(59, 255, 136, 0);
    }
  }

  /* photo gallery */
  .gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    align-items: flex-start;
  }
  .photo {
    position: relative;
    background: #0c0e10;
    border: 1px solid var(--line);
    padding: 9px 9px 30px;
    transition:
      transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.3s,
      border-color 0.3s;
  }
  .photo .img-empty {
    display: block;
  }
  .photo .ph-cap {
    position: absolute;
    bottom: 8px;
    left: 10px;
    font-size: 9.5px;
    letter-spacing: 0.06em;
    color: var(--dim);
  }
  .photo:nth-child(odd) {
    transform: rotate(-2.2deg);
  }
  .photo:nth-child(even) {
    transform: rotate(1.8deg);
  }
  .photo:hover {
    transform: rotate(0deg) translateY(-6px);
    border-color: var(--accent);
    box-shadow: 0 20px 44px -18px rgba(0, 0, 0, 0.9);
    z-index: 5;
  }

  /* closing */
  .closing {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
    padding: clamp(34px, 5vw, 60px) 0;
    border-top: 1px solid var(--line);
  }
  .closing h2 {
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 1;
  }
  .closing h2 em {
    font-style: normal;
    color: transparent;
    -webkit-text-stroke: 1.3px var(--ink);
  }

  @media (max-width: 860px) {
    .bio {
      grid-template-columns: 1fr;
    }
    .portrait {
      max-width: 280px;
    }
    .cubegrid {
      grid-template-columns: 1fr;
    }
    .skills {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .skills {
      grid-template-columns: 1fr;
    }
    .albums {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
