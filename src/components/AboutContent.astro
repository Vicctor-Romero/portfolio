import { getLangFromUrl, useTranslations } from "../i18n/utils";
import InteractiveCube from "./InteractiveCube.tsx";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function getLocalizedPath(path: string) {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (lang === "es") return `/es${cleanPath}`;
  return cleanPath;
}

const skills = [
  { h: "Frontend", items: ["React", "Next.js", "TypeScript", "Tailwind"] },
  { h: "Backend", items: ["NestJS", "Node.js", "PostgreSQL", "REST / GraphQL"] },
  { h: "Mobile", items: ["React Native", "Expo", "Push / OTA", "App Store / Play"] },
  { h: "Infra", items: ["Docker", "CI / CD", "AWS / Vercel", "Git"] },
];

